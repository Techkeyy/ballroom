# Ball Room configuration

# Solana RPC for wallet sign-in + on-chain TxLINE activation (defaults to devnet).
NEXT_PUBLIC_SOLANA_RPC=

# Data source. true = built-in simulator (no API key needed, always demoable).
# Set to false once you've activated a TxLINE token and want live data.
NEXT_PUBLIC_TXLINE_MOCK=true

# --- Real TxLINE (used only when NEXT_PUBLIC_TXLINE_MOCK=false) --------------
# Docs: https://txline.txodds.com/documentation/quickstart
# Auth model:
#   1. Server auto-fetches a guest JWT  (POST /auth/guest/start)
#   2. On-chain: sign the tx from POST /api/guest/purchase/quote with your
#      Solana wallet, then POST /api/token/activate { txSig, walletSignature,
#      leagues:[<worldCupId>] } -> returns the api token below.
#      (This on-chain activation IS the app's Solana sign-up.)
TXLINE_BASE_URL=https://txline.txodds.com/api
TXLINE_API_TOKEN=
# World Cup competition id (confirmed against live data: World Cup = 72,
# International Friendlies = 430).
TXLINE_COMPETITION_ID=72
